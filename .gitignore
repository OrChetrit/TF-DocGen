# =============================================================================
# TF-DocGen — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.env/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
*.xml

# Type checkers
.mypy_cache/
.dmypy.json
.pyright/

# ---------------------------------------------------------------------------
# Secrets & Environment Files
# ---------------------------------------------------------------------------
.env
.env.*
*.env
*.secret
secrets.yml
secrets.yaml

# ---------------------------------------------------------------------------
# Terraform
# ---------------------------------------------------------------------------
# Local .terraform directory (downloaded providers/modules)
.terraform/

# Terraform state files — may contain sensitive resource metadata
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Plan files — may contain sensitive data
*.tfplan

# Variable files with sensitive values (override files are safe to ignore too)
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock file (keep this if you want reproducible provider versions)
# Uncomment to ignore:
# .terraform.lock.hcl

# Crash logs generated by Terraform
crash.log
crash.*.log

# ---------------------------------------------------------------------------
# OS artefacts
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
